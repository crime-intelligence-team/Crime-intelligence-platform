# Copy this to .env for local dev. Never commit the real .env.

# Postgres
DATABASE_URL=postgresql+psycopg2://cip:cip_dev_password@postgres:5432/cip

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cip_dev_password

# Auth
JWT_SECRET_KEY=change_this_in_every_environment
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
SESSION_INACTIVITY_EXPIRE_MINUTES=15

# App
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
